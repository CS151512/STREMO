#---------
# VERSION
# --------
PG_VERSION=alpine3.20
REDIS_VERSION=alpine3.20
ZK_VERSION=
KAFKA_VERSION=
CLICKHOUSE_VERSION=
K3S_VERSION=
PROMETHEUS_VERSION=
GRAFANA_VERSION=
#---------
# Micro-service
# --------
WEB_UI_PORT=8080
AUTH_SERVICE_PORT=8081
BFF_SERVICE_PORT=8082
SMT_SERVICE_PORT=8083
STREAMIN_SERVICE_PORT=8084

#---------
# Postgres
# --------
PG_HOST=localhost #заменить при выкате в прод!
PG_VERSION=16
PG_DB=postgres
PG_USER=root
PG_PASSWORD=SET_SECRET_PASS
PG_POST=5433
PG_ADMIN_PORT=5050

POSTGRES_DSN=postgres://root:SET_SECRET_PASS@postgres:PORT/postgres?sslmode=disable

MS_ACCOUNTS_USER=accounts
MS_ACCOUNTS_DB=accounts
MS_ACCOUNTS_PASSWORD=SET_SECRET_PASS

#---------
# Redis
# --------

REDIS_PASSWORD=SET_SECRET_PASS
REDIS_USER_PASSWORD=SET_SECRET_PASS
REDIS_USER=redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0


#---------
# ClickHouse
# --------
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=root
CLICKHOUSE_PASSWORD=SET_SECRET_PASS
CLICKHOUSE_DATABASE=default
CLICKHOUSE_SECURE=false

#---------
# S3 Yandex Cloude
# --------
YANDEX_S3_BUCKET=SET_BUCKET_NAME
YANDEX_S3_ENDPOINT=https://yandexcloud.net
YANDEX_S3_ACCESS_KEY_ID=SET_SECRET_PASS
YANDEX_S3_SECRET_ACCESS_KEY=SET_SECRET_PASS
YANDEX_S3_REGION=ru-central1


#---------
# JWT & AUTH
# --------
JWT_KEY=CHANGE!!!!!!
ACCESS_TTL=1800
REFRESH_TTL=604800
